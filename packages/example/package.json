{
  "name": "matchstick-ts-example",
  "private": true,
  "description": "Reference subgraph and integration tests for matchstick-ts (also serves as usage docs).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "codegen": "graph codegen",
    "pretest": "pnpm codegen && pnpm compile",
    "test": "node --test --test-concurrency=1 integration/*.test.ts",
    "test:fast": "pnpm codegen && node --test integration/synthetic-events.test.ts",
    "test:e2e": "pnpm pretest && node --test --test-concurrency=1 integration/hardhat-e2e.test.ts"
  },
  "dependencies": {
    "@graphprotocol/graph-ts": "0.37.0",
    "matchstick-ts": "workspace:*"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.8",
    "@nomicfoundation/hardhat-viem": "^3.0.7",
    "@types/node": "^22.0.0",
    "assemblyscript": "^0.19.23",
    "hardhat": "^3.4.0",
    "hardhat-matchstick-ts": "workspace:*",
    "matchstick-as": "0.6.0",
    "typescript": "^5.9.3",
    "viem": "^2.37.9"
  }
}
