{
  "name": "hardhat-matchstick-ts",
  "version": "0.3.0",
  "description": "Hardhat 3 plugin for matchstick-ts subgraph snapshot tests.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsheva/matchstick-ts.git",
    "directory": "packages/hardhat-matchstick-ts"
  },
  "bugs": "https://github.com/lsheva/matchstick-ts/issues",
  "homepage": "https://github.com/lsheva/matchstick-ts#readme",
  "keywords": [
    "hardhat",
    "hardhat-plugin",
    "the-graph",
    "subgraph",
    "matchstick"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "typescript": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node-entry.ts",
      "typescript": "./src/node-entry.ts",
      "default": "./dist/node-entry.js"
    },
    "./config": {
      "types": "./src/type-extensions.ts",
      "typescript": "./src/type-extensions.ts",
      "default": "./dist/type-extensions.js"
    },
    "./network": {
      "types": "./src/network-type-extensions.ts",
      "typescript": "./src/network-type-extensions.ts",
      "default": "./dist/network-type-extensions.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "node ./scripts/prepare.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "matchstick-ts": "link:../matchstick-ts"
  },
  "peerDependencies": {
    "hardhat": "^3",
    "@nomicfoundation/hardhat-viem": "^3",
    "@nomicfoundation/hardhat-network-helpers": "^3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^3.0.8",
    "@nomicfoundation/hardhat-viem": "^3.0.7",
    "@types/node": "^22.0.0",
    "hardhat": "^3.4.0",
    "matchstick-ts": "workspace:*",
    "typescript": "^5.9.3",
    "viem": "^2.37.9"
  }
}
