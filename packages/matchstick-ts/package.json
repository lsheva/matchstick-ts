{
  "name": "matchstick-ts",
  "version": "0.3.0",
  "description": "Typed snapshot testing for The Graph subgraphs via Matchstick — assertions in TypeScript.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsheva/matchstick-ts.git",
    "directory": "packages/matchstick-ts"
  },
  "bugs": "https://github.com/lsheva/matchstick-ts/issues",
  "homepage": "https://github.com/lsheva/matchstick-ts#readme",
  "keywords": [
    "the-graph",
    "subgraph",
    "matchstick",
    "assemblyscript",
    "testing"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "typescript": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./codegen": {
      "types": "./src/codegen/index.ts",
      "typescript": "./src/codegen/index.ts",
      "default": "./dist/codegen/index.js"
    },
    "./assembly": "./assembly/index.ts"
  },
  "bin": {
    "matchstick-ts": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "src",
    "assembly"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "graphql": "^16.11.0",
    "yaml": "^2.5.0"
  },
  "peerDependencies": {
    "@graphprotocol/graph-cli": ">=0.90",
    "@graphprotocol/graph-ts": ">=0.37",
    "matchstick-as": ">=0.6",
    "viem": "^2"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@graphprotocol/graph-ts": "0.37.0",
    "@types/node": "^22.0.0",
    "matchstick-as": "0.6.0",
    "typescript": "^5.9.3",
    "viem": "^2.37.9"
  }
}
