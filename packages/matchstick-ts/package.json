{
  "name": "matchstick-ts",
  "version": "0.1.0",
  "description": "Typed snapshot testing for The Graph subgraphs via Matchstick — assertions in TypeScript.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsheva/matchstick-ts.git",
    "directory": "packages/matchstick-ts"
  },
  "bugs": "https://github.com/lsheva/matchstick-ts/issues",
  "homepage": "https://github.com/lsheva/matchstick-ts#readme",
  "keywords": [
    "the-graph",
    "subgraph",
    "matchstick",
    "assemblyscript",
    "testing"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./codegen": "./src/codegen/index.ts",
    "./assembly": "./assembly/index.ts"
  },
  "bin": {
    "matchstick-ts": "./src/bin/cli.ts"
  },
  "files": [
    "src",
    "assembly"
  ],
  "scripts": {
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "graphql": "^16.11.0",
    "yaml": "^2.5.0"
  },
  "peerDependencies": {
    "@graphprotocol/graph-ts": ">=0.37",
    "matchstick-as": ">=0.6",
    "viem": "^2"
  },
  "devDependencies": {
    "@graphprotocol/graph-ts": "0.37.0",
    "@types/node": "^22.0.0",
    "matchstick-as": "0.6.0",
    "typescript": "^5.9.3",
    "viem": "^2.37.9"
  }
}
